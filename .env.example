# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ===== OpenAI =====
OPENAI_API_KEY=sk-...

# ===== Cloudflare (shared) =====
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token   # ต้องมีสิทธิ์ D1:Edit + R2:Edit

# ===== Cloudflare D1 (knowledge base) =====
CF_D1_DATABASE_ID=your_d1_database_id

# ===== Cloudflare R2 (รูปภาพ) =====
CF_R2_BUCKET_NAME=your-bucket-name
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# ===== Google Sheets =====
GOOGLE_SHEETS_CRED_PATH=google-sheets-cred.json
GOOGLE_SHEET_ID=your_spreadsheet_id_here
