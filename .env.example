# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ===== OpenAI =====
OPENAI_API_KEY=sk-...

# ===== Firebase (Firestore) =====
# วางเนื้อหา JSON ของ Service Account ทั้งหมดในบรรทัดเดียว (escape newline)
# หรือใส่ path ไปยังไฟล์ JSON
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# ===== Google Sheets =====
GOOGLE_SHEETS_CRED_PATH=google-sheets-cred.json
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ===== Cloudflare R2 =====
CF_R2_BUCKET_NAME=your-bucket-name
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_R2_ACCOUNT_ID=your_cloudflare_account_id
# Public URL prefix สำหรับเข้าถึงไฟล์ใน R2 (ถ้ามี custom domain ให้ใส่ตรงนี้)
CF_R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev
